  @@index([planId])
  @@index([endDate])
  @@map("user_subscriptions")
}

model Payment {
  id                   String         @id @default(uuid())
  userId               String?        @map("user_id")
  amount               Decimal        @db.Decimal(10, 2)
  currency             String         @default("INR")
  status               PaymentStatus  @default(PENDING)
  method               PaymentMethod?
  paymentFor           PaymentFor     @map("payment_for")
  referenceId          String?        @map("reference_id") // subscription/campaign/etc ID
  gatewayOrderId       String?        @map("gateway_order_id")
  gatewayPaymentId     String?        @map("gateway_payment_id")
  gatewaySignature     String?        @map("gateway_signature")
  gatewayResponse      Json?          @map("gateway_response")
  subscriptionId       String?        @map("subscription_id")
  gstAmount            Decimal?       @db.Decimal(10, 2) @map("gst_amount")
