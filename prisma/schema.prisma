model AdSlot {
  id            String         @id @default(uuid())
  name          String
  position      AdSlotPosition @unique
  description   String?
  width         Int?
  height        Int?
  isActive      Boolean        @default(true) @map("is_active")
  isPremium     Boolean        @default(false) @map("is_premium")
  pricePerDay   Decimal?       @db.Decimal(10, 2) @map("price_per_day")
  pricePerWeek  Decimal?       @db.Decimal(10, 2) @map("price_per_week")
  pricePerMonth Decimal?       @db.Decimal(10, 2) @map("price_per_month")
  networkCode   String?        @map("network_code")  // AdSense slot code etc.
  networkProvider AdNetworkProvider? @map("network_provider")
  fillRate      Decimal?       @db.Decimal(5, 2) @map("fill_rate")
  avgCtr        Decimal?       @db.Decimal(5, 4) @map("avg_ctr")
  avgCpm        Decimal?       @db.Decimal(10, 2) @map("avg_cpm")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  campaigns AdCampaign[]

  @@map("ad_slots")
}

model AdCampaign {
  id            String         @id @default(uuid())
  advertiserId  String         @map("advertiser_id")
  slotId        String?        @map("slot_id")
  name          String
  status        CampaignStatus @default(DRAFT)
  budget        Decimal        @db.Decimal(12, 2)
  spent         Decimal        @default(0) @db.Decimal(12, 2)
  startDate     DateTime       @map("start_date")
  endDate       DateTime       @map("end_date")
  targetStates  Json?          @map("target_states")   // array of state codes
  targetDevices Json?          @map("target_devices")  // desktop/mobile/tablet
  impressions   BigInt         @default(0)
  clicks        BigInt         @default(0)
  conversions   BigInt         @default(0)
  ctr           Decimal?       @db.Decimal(5, 4)
  cpm           Decimal?       @db.Decimal(10, 2)
  notes         String?
  rejectedReason String?       @map("rejected_reason")
  approvedAt    DateTime?      @map("approved_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  advertiser Advertiser   @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  slot       AdSlot?      @relation(fields: [slotId], references: [id], onDelete: SetNull)
  creatives  AdCreative[]

  @@index([advertiserId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("ad_campaigns")
}

model AdCreative {
  id          String    @id @default(uuid())
  campaignId  String    @map("campaign_id")
  name        String
  type        String    // BANNER | VIDEO | NATIVE | HTML
  fileUrl     String    @map("file_url")
  clickUrl    String    @map("click_url")
  altText     String?   @map("alt_text")
  width       Int?
  height      Int?
  fileSize    BigInt?   @map("file_size")
  duration    Int?      // seconds for video
  isApproved  Boolean   @default(false) @map("is_approved")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("ad_creatives")
}

// ============================================================================
// Revenue Snapshots (for fast dashboard queries)
// ============================================================================

model RevenueSnapshot {
  id            String    @id @default(uuid())
  date          DateTime  @db.Date
  source        String    // adsense | adsterra | direct | subscription | press_release | marketplace
  country       String?
  state         String?
