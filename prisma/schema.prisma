enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  DORMANT
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  EMAIL
  SOCIAL_MEDIA
  ADVERTISEMENT
  EVENT
  PARTNER
  OTHER
}

model Lead {
  id            String     @id @default(uuid())
  name          String
  email         String?
  phone         String?
  company       String?
  designation   String?
  source        LeadSource @default(WEBSITE)
  status        LeadStatus @default(NEW)
  pipelineStage Int        @default(0) @map("pipeline_stage") // 0-6 mapped to LeadStatus
  value         Decimal?   @db.Decimal(12, 2)
  currency      String     @default("INR")
  assignedTo    String?    @map("assigned_to") // User ID
  tags          Json?
  city          String?
  state         String?
  notes         String?
  lastContactedAt DateTime? @map("last_contacted_at")
  expectedCloseAt DateTime? @map("expected_close_at")
