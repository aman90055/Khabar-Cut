// ============================================================================
// Khabar Cut News — Enterprise News Platform
// Prisma Schema (PostgreSQL)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

enum AdType {
  BANNER
  SIDEBAR
  INLINE
  POPUP
  NATIVE
}

enum AdPosition {
  HEADER
  SIDEBAR
  ARTICLE_TOP
  ARTICLE_BOTTOM
  ARTICLE_INLINE
  FOOTER
  POPUP
}

enum NotificationType {
  ARTICLE_PUBLISHED
  COMMENT_RECEIVED
  COMMENT_APPROVED
  ROLE_CHANGED
  SYSTEM
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum ArticleVisibility {
  PUBLIC
  PRIVATE
  SUBSCRIBERS_ONLY
}

enum LiveBlogStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum WebStoryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum VideoStatus {
  DRAFT
  PROCESSING
  PUBLISHED
  ARCHIVED
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

// ============================================================================
// Auth & RBAC
// ============================================================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  fullName     String    @map("full_name")
  avatarUrl    String?   @map("avatar_url")
  phone        String?
  bio          String?
  authProvider String    @map("auth_provider")
  authId       String    @unique @map("auth_id")
  roleId       String    @map("role_id")
  isActive     Boolean   @default(true) @map("is_active")
  isVerified   Boolean   @default(false) @map("is_verified")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  articles      Article[]
  comments      Comment[]
  bookmarks     Bookmark[]
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]
  media         Media[]
  author        Author?

  @@index([email])
  @@index([authId])
  @@index([roleId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  level       Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users       User[]
  permissions RolePermission[]

  @@index([level])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================================
// Content
// ============================================================================

model Article {
  id              String            @id @default(uuid())
  title           String
  slug            String            @unique
  excerpt         String?
  content         Json?
  featuredImageId String?           @map("featured_image_id")
  categoryId      String?           @map("category_id")
  authorId        String            @map("author_id")
  status          ArticleStatus     @default(DRAFT)
  visibility      ArticleVisibility @default(PUBLIC)
  priority        Int               @default(0)
  isFeatured      Boolean           @default(false) @map("is_featured")
  isBreaking      Boolean           @default(false) @map("is_breaking")
  publishedAt     DateTime?         @map("published_at")
  scheduledAt     DateTime?         @map("scheduled_at")
  wordCount       Int?              @map("word_count")
  readingTime     Int?              @map("reading_time")
  viewCount       BigInt            @default(0) @map("view_count")
  stateId         String?           @map("state_id")
  districtId      String?           @map("district_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author        User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  featuredImage Media?        @relation(fields: [featuredImageId], references: [id], onDelete: SetNull)
  state         State?        @relation(fields: [stateId], references: [id], onDelete: SetNull)
  district      District?     @relation(fields: [districtId], references: [id], onDelete: SetNull)
  tags          ArticleTag[]
  comments      Comment[]
  seoMetadata   SeoMetadata[]
  bookmarks     Bookmark[]
  breakingNews  BreakingNews[]
  analytics     Analytics[]

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([status, publishedAt])
  @@index([publishedAt(sort: Desc)])
  @@index([stateId])
  @@index([districtId])
  @@map("articles")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  parentId    String?  @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  articles Article[]
  videos   Video[]

  @@index([slug])
  @@index([parentId])
  @@index([sortOrder])
  @@map("categories")
}

model Tag {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  articles ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@map("article_tags")
}

// ============================================================================
// Media
// ============================================================================

model Media {
  id           String    @id @default(uuid())
  filename     String
  originalName String    @map("original_name")
  mimeType     String    @map("mime_type")
  size         BigInt
  width        Int?
  height       Int?
  url          String
  thumbnailUrl String?   @map("thumbnail_url")
  altText      String?   @map("alt_text")
  caption      String?
  storagePath  String    @map("storage_path")
  bucket       String
  uploadedById String    @map("uploaded_by_id")
  type         MediaType
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  uploadedBy User      @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  articles   Article[]

  @@index([uploadedById])
  @@index([type])
  @@index([createdAt])
  @@map("media")
}

// ============================================================================
// Engagement
// ============================================================================

model Comment {
  id        String        @id @default(uuid())
  content   String
  articleId String        @map("article_id")
  userId    String        @map("user_id")
  parentId  String?       @map("parent_id")
  status    CommentStatus @default(PENDING)
  ipAddress String?       @map("ip_address")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  article Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentThread")

  @@index([articleId])
  @@index([userId])
  @@index([parentId])
  @@index([status])
  @@map("comments")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  articleId String   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("bookmarks")
}

// ============================================================================
// Notifications
// ============================================================================

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================================================
// Advertising
// ============================================================================

model Advertisement {
  id          String     @id @default(uuid())
  title       String
  type        AdType
  content     String?
  targetUrl   String?    @map("target_url")
  imageUrl    String?    @map("image_url")
  startDate   DateTime   @map("start_date")
  endDate     DateTime   @map("end_date")
  isActive    Boolean    @default(true) @map("is_active")
  impressions BigInt     @default(0)
  clicks      BigInt     @default(0)
  position    AdPosition
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  @@index([isActive, position])
  @@index([startDate, endDate])
  @@map("advertisements")
}

// ============================================================================
// Analytics & Audit
// ============================================================================

model Analytics {
  id         String   @id @default(uuid())
  articleId  String?  @map("article_id")
  pagePath   String   @map("page_path")
  eventType  String   @map("event_type")
  referrer   String?
  userAgent  String?  @map("user_agent")
  ipHash     String?  @map("ip_hash")
  country    String?
  region     String?
  deviceType String?  @map("device_type")
  sessionId  String?  @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([articleId, createdAt])
  @@index([pagePath])
  @@index([createdAt])
  @@map("analytics")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// Sessions
// ============================================================================

model Session {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  tokenHash    String    @unique @map("token_hash")
  deviceInfo   Json?     @map("device_info")
  ipAddress    String?   @map("ip_address")
  expiresAt    DateTime  @map("expires_at")
  lastActiveAt DateTime  @default(now()) @map("last_active_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================================================
// Author Profiles
// ============================================================================

model Author {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  displayName String   @map("display_name")
  slug        String   @unique
  bio         String?
  avatarUrl   String?  @map("avatar_url")
  socialLinks Json?    @map("social_links")
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  webStories WebStory[]
  videos     Video[]
  liveBlogs  LiveBlog[]
  liveBlogEntries LiveBlogEntry[]

  @@index([slug])
  @@index([userId])
  @@map("authors")
}

// ============================================================================
// Geography
// ============================================================================

model State {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  districts District[]
  articles  Article[]

  @@map("states")
}

model District {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  stateId   String   @map("state_id")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  state    State     @relation(fields: [stateId], references: [id], onDelete: Cascade)
  articles Article[]

  @@index([slug])
  @@index([stateId])
  @@index([stateId, slug])
  @@map("districts")
}

// ============================================================================
// Breaking News
// ============================================================================

model BreakingNews {
  id        String    @id @default(uuid())
  title     String
  articleId String?   @map("article_id")
  isActive  Boolean   @default(true) @map("is_active")
  priority  Int       @default(0)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([isActive, priority])
  @@index([expiresAt])
  @@map("breaking_news")
}

// ============================================================================
// Web Stories
// ============================================================================

model WebStory {
  id          String         @id @default(uuid())
  title       String
  slug        String         @unique
  coverImage  String?        @map("cover_image")
  slides      Json
  authorId    String         @map("author_id")
  status      WebStoryStatus @default(DRAFT)
  publishedAt DateTime?      @map("published_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  author Author @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@map("web_stories")
}

// ============================================================================
// Videos
// ============================================================================

model Video {
  id           String      @id @default(uuid())
  title        String
  slug         String      @unique
  description  String?
  videoUrl     String      @map("video_url")
  thumbnailUrl String?     @map("thumbnail_url")
  duration     Int?
  categoryId   String?     @map("category_id")
  authorId     String      @map("author_id")
  status       VideoStatus @default(DRAFT)
  viewCount    BigInt      @default(0) @map("view_count")
  isFeatured   Boolean     @default(false) @map("is_featured")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author   Author    @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@map("videos")
}

// ============================================================================
// Live Blogs
// ============================================================================

model LiveBlog {
  id          String         @id @default(uuid())
  title       String
  slug        String         @unique
  description String?
  authorId    String         @map("author_id")
  status      LiveBlogStatus @default(ACTIVE)
  startedAt   DateTime       @default(now()) @map("started_at")
  endedAt     DateTime?      @map("ended_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  author  Author          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  entries LiveBlogEntry[]

  @@index([slug])
  @@index([status])
  @@map("live_blogs")
}

model LiveBlogEntry {
  id         String   @id @default(uuid())
  liveBlogId String   @map("live_blog_id")
  content    Json
  authorId   String   @map("author_id")
  isPinned   Boolean  @default(false) @map("is_pinned")
  entryType  String   @default("update") @map("entry_type")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  liveBlog LiveBlog @relation(fields: [liveBlogId], references: [id], onDelete: Cascade)
  author   Author   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([liveBlogId, createdAt])
  @@map("live_blog_entries")
}

// ============================================================================
// SEO
// ============================================================================

model SeoMetadata {
  id               String   @id @default(uuid())
  entityType       String   @map("entity_type")
  entityId         String   @map("entity_id")
  metaTitle        String?  @map("meta_title")
  metaDescription  String?  @map("meta_description")
  canonicalUrl     String?  @map("canonical_url")
  ogTitle          String?  @map("og_title")
  ogDescription    String?  @map("og_description")
  ogImage          String?  @map("og_image")
  twitterTitle     String?  @map("twitter_title")
  twitterDescription String? @map("twitter_description")
  focusKeyword     String?  @map("focus_keyword")
  schemaMarkup     Json?    @map("schema_markup")
  noIndex          Boolean  @default(false) @map("no_index")
  noFollow         Boolean  @default(false) @map("no_follow")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  article Article? @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId])
  @@index([entityType])
  @@map("seo_metadata")
}

// ============================================================================
// Settings
// ============================================================================

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  group       String?
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([group])
  @@map("settings")
}

// ============================================================================
// Subscribers & Newsletters
// ============================================================================

model Subscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String?
  status         String    @default("pending")
  confirmedAt    DateTime? @map("confirmed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  preferences    Json?
  source         String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  subscriptions NewsletterSubscription[]

  @@index([status])
  @@map("subscribers")
}

model Newsletter {
  id             String           @id @default(uuid())
  title          String
  subject        String
  content        Json?
  status         NewsletterStatus @default(DRAFT)
  sentAt         DateTime?        @map("sent_at")
  recipientCount Int              @default(0) @map("recipient_count")
  openCount      Int              @default(0) @map("open_count")
  clickCount     Int              @default(0) @map("click_count")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  subscriptions NewsletterSubscription[]

  @@index([status])
  @@index([sentAt])
  @@map("newsletters")
}

model NewsletterSubscription {
  id           String    @id @default(uuid())
  subscriberId String    @map("subscriber_id")
  newsletterId String    @map("newsletter_id")
  sentAt       DateTime? @map("sent_at")
  openedAt     DateTime? @map("opened_at")
  clickedAt    DateTime? @map("clicked_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  newsletter Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, newsletterId])
  @@map("newsletter_subscriptions")
}

// ============================================================================
// Revenue & Subscription System
// ============================================================================

enum SubscriptionBillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
  PAST_DUE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  CASHFREE
  UPI
  CARD
  NET_BANKING
  INTERNATIONAL
}

enum PaymentFor {
  SUBSCRIPTION
  AD_CAMPAIGN
  PRESS_RELEASE
  MARKETPLACE
  BUSINESS_LISTING
  SERVICE
}

model SubscriptionPlan {
  id              String                  @id @default(uuid())
  name            String
  slug            String                  @unique
  description     String?
  price           Decimal                 @db.Decimal(10, 2)
  currency        String                  @default("INR")
  billingCycle    SubscriptionBillingCycle @map("billing_cycle")
  trialDays       Int                     @default(0) @map("trial_days")
  isActive        Boolean                 @default(true) @map("is_active")
  isFeatured      Boolean                 @default(false) @map("is_featured")
  features        Json                    // array of feature strings
  adFree          Boolean                 @default(false) @map("ad_free")
  exclusiveContent Boolean               @default(false) @map("exclusive_content")
  premiumVideos   Boolean                 @default(false) @map("premium_videos")
