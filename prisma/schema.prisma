  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  @@index([priority])
  @@index([createdAt])
  @@map("wire_items")
}

// ============================================================================
// Podcast Platform
// ============================================================================

model Podcast {
  id          String           @id @default(uuid())
  title       String
  description String?
  coverUrl    String?          @map("cover_url")
  language    String           @default("en")
  authorId    String           @map("author_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  episodes    PodcastEpisode[]

  @@map("podcasts")
}

model PodcastEpisode {
  id          String    @id @default(uuid())
  podcastId   String    @map("podcast_id")
  title       String
  description String?
  audioUrl    String    @map("audio_url")
  duration    Int       @default(0) // in seconds
  transcript  String?   @db.Text
  aiSummary   String?   @map("ai_summary") @db.Text
  downloadCount Int     @default(0) @map("download_count")
  publishAt   DateTime  @default(now()) @map("publish_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@index([podcastId])
  @@map("podcast_episodes")
}

// ============================================================================
// Live TV Channel & EPG
// ============================================================================

model LiveTVChannel {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  streamUrl   String       @map("stream_url")
  logoUrl     String?      @map("logo_url")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  programs    EpgProgram[]

  @@map("live_tv_channels")
}

model EpgProgram {
  id          String    @id @default(uuid())
  channelId   String    @map("channel_id")
  title       String
  description String?
  startAt     DateTime  @map("start_at")
  endAt       DateTime  @map("end_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  channel LiveTVChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([startAt, endAt])
  @@map("epg_programs")
}

// ============================================================================
// Global User Settings & Preferences
// ============================================================================

model GlobalUserPreferences {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  currency       String   @default("USD")
  timezone       String   @default("UTC")
  language       String   @default("en")
  savedFeedCount Int      @default(0) @map("saved_feed_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("global_user_preferences")
}


