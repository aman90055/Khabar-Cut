  notes                String?
  refundedAt           DateTime?      @map("refunded_at")
  refundAmount         Decimal?       @db.Decimal(10, 2) @map("refund_amount")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")

  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?

  @@index([userId, status])
  @@index([paymentFor])
  @@index([createdAt])
  @@index([status])
  @@map("payments")
}

model Invoice {
  id              String    @id @default(uuid())
  paymentId       String    @unique @map("payment_id")
  invoiceNumber   String    @unique @map("invoice_number")
  buyerName       String    @map("buyer_name")
  buyerEmail      String    @map("buyer_email")
  buyerPhone      String?   @map("buyer_phone")
  buyerAddress    String?   @map("buyer_address")
  buyerGst        String?   @map("buyer_gst")
  sellerName      String    @default("Khabar Cut Media Pvt. Ltd.") @map("seller_name")
  sellerGst       String?   @map("seller_gst")
  items           Json      // line items
  subtotal        Decimal   @db.Decimal(10, 2)
  gstAmount       Decimal   @db.Decimal(10, 2) @map("gst_amount")
  totalAmount     Decimal   @db.Decimal(10, 2) @map("total_amount")
  currency        String    @default("INR")
  issueDate       DateTime  @map("issue_date")
  dueDate         DateTime? @map("due_date")
  pdfUrl          String?   @map("pdf_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

