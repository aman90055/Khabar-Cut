  followups    LeadFollowUp[]

  @@index([status])
  @@index([assignedTo])
  @@index([source])
  @@map("leads")
}

enum LeadNoteType {
  GENERAL
  CALL
  EMAIL
  WHATSAPP
  MEETING
}

model LeadNote {
  id        String       @id @default(uuid())
